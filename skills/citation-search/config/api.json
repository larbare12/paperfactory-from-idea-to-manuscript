{
  "api": {
    "semantic_scholar": {
      "base_url": "https://s2api.ominiai.cn/s2",
      "api_key_header": "Authorization",
      "api_key_env_var": "S2_API_KEY",
      "rate_limit_min_interval": 1
    },
    "crossref": {
      "base_url": "https://api.crossref.org"
    },
    "doi": {
      "base_url": "https://doi.org"
    },
    "arxiv": {
      "base_url": "http://export.arxiv.org/api/query",
      "_note": "Used by --mode multi via the `arxiv` Python package; no key required."
    },
    "openalex": {
      "base_url": "https://api.openalex.org",
      "mailto": null,
      "_note": "Used by --mode multi. Set `mailto` to your email (or env OPENALEX_MAILTO) to join the polite pool."
    }
  }
}
