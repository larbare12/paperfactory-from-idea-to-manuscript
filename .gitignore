# 密钥与本地环境（注意：.env.example 应保留入库）
.env
.env.local

# IDE / 编辑器
.idea/
.vscode/

# Claude Code 本地设置
.claude/

# 系统垃圾
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.swp
*~

# Working passport — instance file (per-paper). passport.example.yaml is committed for reference.
passport.yaml
passport.*.yaml
!passport.example.yaml

# v0.6+ PDF cache — manifest.jsonl tracks the metadata, PDFs are local-only
# (avoids repo bloat; PDFs may also have copyright issues for redistribution)
relate-work/pdf/*.pdf
# Python bytecode cache
__pycache__/
*.pyc
