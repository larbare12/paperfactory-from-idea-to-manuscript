# 密钥与本地环境（注意：.env.example 应保留入库）
.env
.env.local

# IDE / 编辑器
.idea/
.vscode/

# Claude Code 本地设置
.claude/

# 系统垃圾
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.swp
*~

# Working passport — instance file (per-paper). passport.example.yaml is committed for reference.
passport.yaml
passport.*.yaml
!passport.example.yaml

# v0.6+ relate-work/ is a per-paper project artifact directory and must NOT
# live inside the skill repo. If a `relate-work/` accidentally appears here
# (e.g. when running the scripts from the skill repo itself for testing),
# don't track it. Real usage: `cd <your-paper-project> && bash <skill>/script/...`
relate-work/

# Python bytecode cache
__pycache__/
*.pyc
